[{"updatedAt":"2026-04-01T03:23:13.000Z","createdAt":"2026-04-01T02:10:35.600Z","id":"XXBL0IL9mkvbkaLm","name":"WorldModels_V32_ULTIMATE","description":null,"active":true,"isArchived":false,"nodes":[{"parameters":{"httpMethod":"POST","path":"worldmodels-platinum-v5","responseMode":"lastNode"},"id":"eZRpzQOdzoJrDbDS-1","name":"Webhook Ingestion","type":"n8n-nodes-base.webhook","typeVersion":1,"position":[0,400]},{"parameters":{"httpMethod":"POST","path":"webhook-test/1fd718d6-49f8-43dc-a881-ff7ecf7b94ef","responseMode":"lastNode"},"id":"eZRpzQOdzoJrDbDS-5","name":"Webhook WhatsApp","type":"n8n-nodes-base.webhook","typeVersion":1,"position":[450,200]},{"parameters":{"jsCode":"// ­ƒºá Extract and unify metadata between Telegram and WhatsApp\nconst item = $input.first().json;\nlet platform = \"\";\nlet sender_contact = \"\";\nlet extracted_text = \"\";\n\nif (item.message) {\n  platform = \"Telegram\";\n  extracted_text = item.message.text || item.message.caption || \"\";\n  sender_contact = item.message.from.username ? `@${item.message.from.username}` : (item.message.from.first_name || item.message.from.id.toString());\n} else if (item.body) {\n  platform = \"WhatsApp\";\n  extracted_text = item.body.text || item.text || item.content || \"\";\n  const num = item.key?.remoteJid?.split('@')[0] || \"\";\n  sender_contact = item.pushName ? `${item.pushName} (${num})` : num;\n} else {\n  platform = \"Unknown\";\n  extracted_text = JSON.stringify(item);\n}\n\nreturn {\n  platform,\n  sender_contact: String(sender_contact).trim(),\n  extracted_text: String(extracted_text).trim(),\n  texto_limpio: String(extracted_text).trim()\n};"},"id":"eZRpzQOdzoJrDbDS-2","name":"Extract Metadata","type":"n8n-nodes-base.code","typeVersion":1,"position":[250,400]},{"parameters":{"jsCode":"const store = $getWorkflowStaticData('global');\nif (!store.seen) store.seen = {};\nconst now = Date.now();\nconst ttl = 60 * 60 * 1000; // 1 hour\nfor (const k in store.seen) {\n  if (now - store.seen[k] > ttl) delete store.seen[k];\n}\nconst raw = String($json.extracted_text || '').toLowerCase().trim().replace(/[^a-z0-9\\u00C0-\\u024F\\u0400-\\u04FF]/gi, '');\nif (raw.length < 15) return items;\nlet hash = 0;\nfor (let i = 0; i < raw.length; i++) {\n  hash = ((hash << 5) - hash) + raw.charCodeAt(i);\n  hash |= 0;\n}\nconst key = String(hash);\nif (store.seen[key]) return [];\nstore.seen[key] = now;\nreturn items;"},"id":"eZRpzQOdzoJrDbDS-3","name":"Check Clone","type":"n8n-nodes-base.code","typeVersion":1,"position":[450,400]},{"parameters":{"jsCode":"// ­ƒºá Enhanced lead validation\nconst items = $input.all();\nconst bannedKeywords = ['crypto','binance','forex','casino','stake','signals','trading','pump'];\nconst qualityKeywords = ['plaza','room','spot','booking','viaje','casting','agency','model','budget'];\n\nconst out = [];\nfor (const item of items) {\n  const text = (item.json.texto_limpio || '').toLowerCase();\n  const hasBanned = bannedKeywords.some(k => text.includes(k));\n  const hasQuality = qualityKeywords.some(k => text.includes(k));\n  const isValuable = !hasBanned && (hasQuality || text.length > 50);\n  \n  out.push({ json: { ...item.json, looksValuable: isValuable, prefilter_v2: true } });\n}\nreturn out;"},"id":"eZRpzQOdzoJrDbDS-4","name":"Prefilter 2","type":"n8n-nodes-base.code","typeVersion":1,"position":[650,400]},{"parameters":{"jsCode":"// ­ƒºá Centralizer code for different platforms and formats\nconst items = $input.all();\nreturn items.map(i => ({\n  json: {\n    ...i.json,\n    balanced_at: new Date().toISOString(),\n    source_id: i.json.platform || \"Unknown\"\n  }\n}));"},"id":"eZRpzQOdzoJrDbDS-8","name":"Balancer Universal","type":"n8n-nodes-base.code","typeVersion":1,"position":[850,350]},{"parameters":{"conditions":{"boolean":[{"value1":"={{ $json.looksValuable }}","value2":true}]}},"id":"eZRpzQOdzoJrDbDS-6","name":"IF VIP","type":"n8n-nodes-base.filter","typeVersion":2,"position":[1050,400]},{"parameters":{"method":"POST","url":"https://api.deepseek.com/chat/completions","headerParameters":{"parameters":[{"name":"Authorization","value":"Bearer {{$env.DEEPSEEK_API_KEY}}"},{"name":"Content-Type","value":"application/json"}]},"sendBody":true,"specifyBody":"json","jsonBody":"={{ {\"model\": \"deepseek-chat\", \"messages\": [{\"role\": \"system\", \"content\": \"### ROLE: WORLDMODELS ELITE EXTRACTOR ###\\nExtract job leads.\"}, {\"role\": \"user\", \"content\": $json.extracted_text}], \"response_format\": {\"type\": \"json_object\"}} }}"},"id":"eZRpzQOdzoJrDbDS-12","name":"AI Brain","type":"n8n-nodes-base.httpRequest","typeVersion":4.1,"position":[1300,300]},{"parameters":{"jsCode":"try {\n  const content = $json[\"content\"];\n  const parts = content[\"parts\"];\n  const rawText = parts[0][\"text\"];\n  const cleanedText = rawText.replace(/```json\\n?|\\n?```/g, '').trim();\n  const parsed = JSON.parse(cleanedText);\n\n  // FIX: Si la IA devuelve una lista [], la procesamos uno a uno\n  if (Array.isArray(parsed)) {\n    return parsed.map(item => ({ ...item, rawText }));\n  } \n  \n  // Si devuelve un solo objeto, lo mandamos directo\n  return { ...parsed, rawText };\n} catch (e) {\n  return { trash: true, rawText: $node[\"Message a model\"].json[\"content\"][\"parts\"][0][\"text\"] };\n}"},"id":"eZRpzQOdzoJrDbDS-13","name":"Parse","type":"n8n-nodes-base.code","typeVersion":1,"position":[1500,300]},{"parameters":{"conditions":{"boolean":[{"value1":"={{ $json.trash }}","value2":false}]}},"id":"eZRpzQOdzoJrDbDS-14","name":"Filter Source","type":"n8n-nodes-base.filter","typeVersion":2,"position":[1700,300]},{"parameters":{"dataType":"string","value1":"={{ $json.category || 'lead' }}","rules":{"rules":[{"value2":"plaza","output":0},{"value2":"evento","output":1}]}},"id":"eZRpzQOdzoJrDbDS-15","name":"Switch","type":"n8n-nodes-base.switch","typeVersion":1,"position":[1900,300]},{"parameters":{"method":"POST","url":"https://worldmodels-jobs.web.app/api/ofertas","sendBody":true,"specifyBody":"json","jsonB