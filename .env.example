# ─────────────────────────────────────────────────────────────────────────────
# WorldModels Jobs — Variables de entorno requeridas
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Cloud / Vertex AI ──────────────────────────────────────────────────
# Ruta al archivo JSON del service account (NO subir el JSON al repo)
GOOGLE_APPLICATION_CREDENTIALS=/ruta/a/service-account.json
GOOGLE_CLOUD_PROJECT=tu-proyecto-gcp
VERTEX_LOCATION=europe-west1

# ── Firebase ─────────────────────────────────────────────────────────────────
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ── WhatsApp / Whapi ─────────────────────────────────────────────────────────
WHAPI_TOKEN=
WHAPI_CHANNEL_ID=
WHAPI_WEBHOOK_URL=

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=

# ── n8n ──────────────────────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_PORT=5678
WEBHOOK_URL=http://localhost:5678

# ── Servidor Express ─────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── DeepSeek (si se usa) ─────────────────────────────────────────────────────
DEEPSEEK_API_KEY=

# ── Seguridad y Hardening ───────────────────────────────────────────────────
# Token para acceder al monitor HTML (server.js)
MONITOR_TOKEN=tu_token_secreto_aqui

# API Key para escritura en Jobs API (jobs_backend.js)
JOBS_API_KEY=tu_api_key_de_jobs_aqui

# Orígenes permitidos para CORS (separados por coma)
ALLOWED_ORIGINS=https://tu-sitio-web.com,http://localhost:3000

# Host del VPS (usado en docker-compose.yml)
VPS_HOST=127.0.0.1
