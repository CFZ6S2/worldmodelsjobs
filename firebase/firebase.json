{
  "functions": { "source": "functions" },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "ssrworldmodelsjobs",
          "region": "europe-west2"
        }
      }
    ]
  }
}
