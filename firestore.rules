rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userRole == 'admin'
      );
    }

    function leadKeys() {
      return [
        'title',
        'description',
        'location',
        'price',
        'category',
        'userId',
        'userEmail',
        'status',
        'timestamp',
        'ingestedAt'
      ];
    }

    function isValidLead(data) {
      return data.keys().hasOnly(leadKeys())
        && data.keys().hasAll(['title', 'description', 'location', 'category', 'userId', 'userEmail', 'status', 'timestamp', 'ingestedAt', 'price'])
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.description is string && data.description.size() > 0 && data.description.size() <= 5000
        && data.location is string && data.location.size() > 0 && data.location.size() <= 200
        && data.price is string && data.price.size() <= 100
        && data.category in ['CAT_PLAZAS', 'CAT_EVENTOS']
        && data.userId is string && data.userId == request.auth.uid
        && data.userEmail is string && data.userEmail.size() <= 320
        && data.status == 'pending'
        && data.timestamp is timestamp
        && data.ingestedAt is string && data.ingestedAt.size() <= 40;
    }

    // Ofertas & Leads: Public read, Admin write
    match /ofertas/{document} {
      allow read: if true;
      allow write: if isAdmin(); 
    }
    match /leads/{document} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && isValidLead(request.resource.data);
      allow update, delete: if isAdmin();
    }
    
    // Lead Hashes: Strictly internal
    match /lead_hashes/{document} {
      allow read, write: if false;
    }
    
    // Users: Only the owner can read/write their own profile, Admin can do anything
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Default: Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
