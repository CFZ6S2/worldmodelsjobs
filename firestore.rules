rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'cesar.herrera.rojo@gmail.com' ||
        request.auth.token.email == 'ceo@worldmodels.com' ||
        (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('role', 'user') == 'admin')
      );
    }

    // 1. Leads and Offers (Ingestion & Public Feed)
    match /ofertas/{docId} {
      allow read: if true;       // Public feed
      allow create: if false;    // Server-side only via Cloud Functions
      allow update: if isAdmin(); // Ban = admin only
      allow delete: if isAdmin();
    }

    match /leads/{docId} {
      allow read: if true;
      allow create: if request.auth != null && 
                    (!exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) || 
                     get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('isBanned', false) != true);
      allow update, delete: if isAdmin() || (request.auth != null && resource.data.authorId == request.auth.uid && 
                             (!exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) || 
                              get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('isBanned', false) != true));
    }

    // 2. Reports (User Moderation Feedback)
    match /reports/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // 3. User Data (Profiles & Settings)
    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin()) &&
                   (!exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) || 
                    get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.isBanned != true);
    }

    // Support for both flat and nested settings structures
    match /user_settings/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
    
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // 4. Activity (Applications)
    match /applications/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource.data.modelId == request.auth.uid || isAdmin());
    }

    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
