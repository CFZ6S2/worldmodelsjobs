      "name": "Webhook WhatsApp",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [450, 200]
    },
    {
      "parameters": {
        "jsCode": "// 🧠 Extract and unify metadata between Telegram and WhatsApp\nconst item = $input.first().json;\nlet platform = \"\";\nlet sender_contact = \"\";\nlet extracted_text = \"\";\n\nif (item.message) {\n  platform = \"Telegram\";\n  extracted_text = item.message.text || item.message.caption || \"\";\n  sender_contact = item.message.from.username ? `@${item.message.from.username}` : (item.message.from.id || \"\");\n} else {\n  platform = \"WhatsApp\";\n  extracted_text = item.body?.text || item.text || item.content || \"\";\n  const num = item.key?.remoteJid?.split('@')[0] || \"\";\n  sender_contact = item.pushName ? `${item.pushName} (${num})` : num;\n}\n\nreturn {\n  platform,\n  sender_contact: String(sender_contact).trim(),\n  extracted_text: String(extracted_text).trim(),\n  texto_limpio: String(extracted_text).trim()\n};"
      },
      "id": "node-meta",
      "name": "Extract Metadata",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [250, 400]
    },
    {
      "parameters": {
        "jsCode": "const store = $getWorkflowStaticData('global');\nif (!store.seen) store.seen = {};\nconst now = Date.now();\nconst ttl = 60 * 60 * 1000; \nfor (const k in store.seen) {\n  if (now - store.seen[k] > ttl) delete store.seen[k];\n}\nconst raw = String($json.extracted_text || '').toLowerCase().trim();\nif (raw.length < 10) return items;\nconst key = Buffer.from(raw).toString('base64').substring(0, 50);\nif (store.seen[key]) return [];\nstore.seen[key] = now;\nreturn items;"
      },
      "id": "node-clone",
      "name": "Check Clone",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [450, 400]
    },
    {
      "parameters": {
        "jsCode": "// 🧠 Lead validation\nconst text = ($json.texto_limpio || \"\").toLowerCase();\nconst banned = ['crypto','binance','forex','casino','stake','signals','trading','pump'];\nconst quality = ['plaza','room','spot','booking','viaje','casting','agency','model','budget'];\n\nconst hasBanned = banned.some(k => text.includes(k));\nconst hasQuality = quality.some(k => text.includes(k));\nconst looksValuable = !hasBanned && (hasQuality || text.length > 50);\n\nreturn [{ ...$json, looksValuable }];"
      },
      "id": "node-prefilter",
      "name": "Prefilter 2",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [650, 400]
    },
    {
      "parameters": {
        "jsCode": "return { ...$json, balanced_at: new Date().toISOString() };"
      },
