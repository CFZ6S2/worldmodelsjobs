{
  "hosting": {
    "public": "web/out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "trailingSlash": true,
    "headers": [
      {
        "source": "**/*.@(js|css|woff2|jpg|png|svg|ico|txt|json)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.txt",
        "headers": [
          {
            "key": "Content-Type",
            "value": "text/plain; charset=utf-8"
          }
        ]
      }
    ],
    "redirects": [
      {
        "source": "/admin",
        "destination": "/es/admin/",
        "type": 301
      },
      {
        "source": "/feed",
        "destination": "/es/feed/",
        "type": 301
      },
      {
        "source": "/login",
        "destination": "/es/auth/login/",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": {
          "id": "api",
          "region": "europe-west1"
        }
      },
      {
        "source": "**/*.@(txt|json|js|css|woff2|jpg|png|svg|ico)",
        "destination": "**/*.@(txt|json|js|css|woff2|jpg|png|svg|ico)"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "firebase/functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
