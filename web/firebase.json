{
  "hosting": {
    "source": ".",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "frameworksBackend": {
      "region": "europe-west1"
    },
    "rewrites": [
      { "source": "/api/**", "function": "api", "region": "europe-west1" },
      { "source": "/panel", "destination": "/panel.html" },
      { "source": "/registro", "destination": "/registro.html" },
      { "source": "/routing", "destination": "/routing.html" }
    ]
  },
  "functions": { "source": "functions" },
  "storage": { "rules": "storage.rules" }
}
