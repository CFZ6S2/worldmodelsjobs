{
  "hosting": {
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/panel", "destination": "/panel.html" },
      { "source": "/registro", "destination": "/registro.html" },
      { "source": "/routing", "destination": "/routing.html" },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
