rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email in ['cesar.herrera.rojo@gmail.com', 'ceo@worldmodels.com', 'gonzalo.hrrj@gmail.com'] ||
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Helper function to check if the user is a VIP
    function isVip() {
      return request.auth != null && 
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.isVip == true;
    }
    
    // Allow public read access to leads for the dashboard feed
    match /leads/{lead} {
      allow read: if true;
      allow create: if isAdmin() || (request.auth != null && 
                    get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.proAgency == true);
      allow update, delete: if isAdmin(); // Allow admins to manage leads
    }

    // match for 'ofertas' collection
    match /ofertas/{oferta} {
      allow read: if true;
      allow create: if isAdmin() || (request.auth != null && 
                    get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.proAgency == true);
      allow update, delete: if isAdmin();
    }

    // User Profiles
    match /profiles/{profile} {
      allow read: if true;
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == profile);
    }

    // Lead Reviews (VIP & Admin feature)
    match /lead_reviews/{review} {
      allow read: if isAdmin() || isVip();
      allow create: if isAdmin() || (isVip() && request.resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
