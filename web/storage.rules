rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /profiles/{userId}/{allPaths=**} {
      // Permitir lectura pública para que se vean las fotos de perfil
      allow read: if true;
      
      // Solo permitir escribir si el usuario está autenticado y es el dueño de la carpeta
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
